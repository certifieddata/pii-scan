{
  "name": "@certifieddata/pii-scan",
  "version": "0.1.1",
  "description": "Local PII risk scanner for datasets \u00e2\u20ac\u201d identifies columns likely containing personal data before synthetic generation",
  "type": "module",
  "bin": {
    "pii-scan": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsc -p tsconfig.json && node --test dist/scanner.test.js dist/cli.test.js",
    "test:unit": "node --test dist/scanner.test.js",
    "test:cli": "node --test dist/cli.test.js",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  },
  "keywords": [
    "certifieddata",
    "pii",
    "privacy",
    "scanner",
    "synthetic-data",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/certifieddata/pii-scan.git"
  }
}
